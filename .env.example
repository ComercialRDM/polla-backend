# Servidor
PORT=4000
FRONTEND_URL=http://localhost:5173
# URL pública del backend (para que ManyChat pueda descargar la imagen del bono)
BACKEND_URL=http://localhost:4000

# Base de datos
DATABASE_URL=postgres://polla_user:polla_pass@localhost:5432/polla_db
DB_SSL=false

# Wompi (usa sandbox para pruebas: https://sandbox.wompi.co/v1)
WOMPI_API_URL=https://production.wompi.co/v1
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxxxxxxxxx

# Admin
ADMIN_API_KEY=cambia-esta-clave-super-secreta

# SMTP (correo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_o_app_password
MAIL_FROM="La Retoucherie de Manuela <tu_correo@gmail.com>"

# Correo que recibe las notificaciones de pronósticos (opcional, por defecto SMTP_USER)
ADMIN_EMAIL=comercial@retoucherie.com.co

# Webhook de marcador en vivo (API-Football u otro proveedor)
# Si se define, el webhook exige el header X-Webhook-Secret con este valor
FUTBOL_WEBHOOK_SECRET=cambia-esta-clave-super-secreta

# football-data.org - actualiza automáticamente los marcadores del Mundial
# Registro gratis en https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=tu_token_de_football-data.org

# ManyChat (notificaciones de gol vía WhatsApp/Messenger)
MANYCHAT_API_URL=https://api.manychat.com
MANYCHAT_API_KEY=tu_token_de_manychat
