# Servidor
PORT=4000
FRONTEND_URL=http://localhost:5173
# URL pública del backend (para que ManyChat pueda descargar la imagen del bono)
BACKEND_URL=http://localhost:4000

# Base de datos
DATABASE_URL=postgres://polla_user:polla_pass@localhost:5432/polla_db
DB_SSL=false

# Wompi (usa sandbox para pruebas: https://sandbox.wompi.co/v1)
WOMPI_API_URL=https://production.wompi.co/v1
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxxxxxxxxx

# Admin
ADMIN_API_KEY=cambia-esta-clave-super-secreta

# SMTP (correo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_o_app_password
MAIL_FROM="La Retoucherie de Manuela <tu_correo@gmail.com>"

# Correo que recibe las notificaciones de pronósticos (opcional, por defecto SMTP_USER)
ADMIN_EMAIL=comercial@retoucherie.com.co

# Copia de control: BCC en cada correo a un cliente, y copia de cada WhatsApp
# saliente vía ManyChat (este número debe haberle escrito antes al WhatsApp
# del negocio, requisito del BSP — si no, la copia falla en silencio).
BCC_COMERCIAL=comercial@retoucherie.com.co
NUMERO_COPIA_CONTROL=573012786234
# subscriber_id numerico de ese contacto en ManyChat (Contacts > abrir el
# contacto > icono de ID) -- la API de ManyChat no tiene forma de buscar un
# suscriptor existente por su WhatsApp ID, asi que se usa este ID fijo.
SUBSCRIBER_ID_COPIA_CONTROL=1486004520

# Webhook de marcador en vivo (API-Football u otro proveedor)
# Si se define, el webhook exige el header X-Webhook-Secret con este valor
FUTBOL_WEBHOOK_SECRET=cambia-esta-clave-super-secreta

# football-data.org - actualiza automáticamente los marcadores del Mundial
# Registro gratis en https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=tu_token_de_football-data.org

# ManyChat (notificaciones de gol vía WhatsApp/Messenger)
MANYCHAT_API_URL=https://api.manychat.com
MANYCHAT_API_KEY=tu_token_de_manychat

# Twilio Verify - envío del código de "Continuar con teléfono" por SMS.
# No se usa WhatsApp/ManyChat para esto: ManyChat es el BSP de esa cuenta y
# retiene la línea de crédito de mensajería, así que una app externa no puede
# enviar en su nombre (error 403/#200 de Meta, confirmado en producción).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_de_twilio
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook de métricas diarias de ManyChat (mensajes enviados, aperturas, clics)
# para el simulador de ingresos del panel admin. Configura este mismo valor
# como header X-Webhook-Secret en la automatización de ManyChat que llama a
# POST /api/webhooks/manychat-metricas
MANYCHAT_METRICAS_SECRET=cambia-esta-clave-super-secreta

# Panel admin: secreto para firmar los tokens de sesión (RBAC role: ADMIN)
ADMIN_JWT_SECRET=cambia-esta-clave-super-secreta

# Cuentas de los locales para redimir bonos en /redimircodigordm (RBAC role: LOCAL)
# Se crean automáticamente al iniciar el servidor si la tabla local_usuarios está vacía.
# Define usuario/contraseña para cada uno de los 5 locales (deja vacíos los que no uses).
LOCAL_SEED_USUARIO_1=local1
LOCAL_SEED_PASSWORD_1=cambia-esta-clave
LOCAL_SEED_NOMBRE_1=Local 1

LOCAL_SEED_USUARIO_2=local2
LOCAL_SEED_PASSWORD_2=cambia-esta-clave
LOCAL_SEED_NOMBRE_2=Local 2

LOCAL_SEED_USUARIO_3=local3
LOCAL_SEED_PASSWORD_3=cambia-esta-clave
LOCAL_SEED_NOMBRE_3=Local 3

LOCAL_SEED_USUARIO_4=local4
LOCAL_SEED_PASSWORD_4=cambia-esta-clave
LOCAL_SEED_NOMBRE_4=Local 4

LOCAL_SEED_USUARIO_5=local5
LOCAL_SEED_PASSWORD_5=cambia-esta-clave
LOCAL_SEED_NOMBRE_5=Local 5
